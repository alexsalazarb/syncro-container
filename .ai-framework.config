# AI Framework Configuration
# Generated by init-repo.sh — edit to customize.
# Read by skills to determine project structure and plans location.

LAYOUT=container
PROJECTS=syncro-flutter:flutter:isolated
CONTAINER_KB_ROOT=docs/kb-container
AI_CONTEXT_ROOT=docs/kb-projects
PLANS_MODE=local
PLANS_DIR=.plans
# PR integration (optional — set PR_INTEGRATION=true to enable)
PR_INTEGRATION=false
AUTO_MERGE_TASK_PRS=false
DEFAULT_BASE_BRANCH=main
# Work-plans hub (optional — set WORK_PLANS_PATH to enable external hub)
WORK_PLANS_PATH=
WORK_PLANS_BRANCH=main
